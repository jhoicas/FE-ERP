# OAuth - Google
VITE_GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID

# OAuth - Microsoft (MSAL)
VITE_MSAL_CLIENT_ID=REPLACE_WITH_MSAL_CLIENT_ID

# Opcional: tenant específico. Usa "common" para multi-tenant
VITE_MSAL_TENANT_ID=common

# Opcional: URL de redirección. Por defecto usa window.location.origin
VITE_MSAL_REDIRECT_URI=http://localhost:5173
